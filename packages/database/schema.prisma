datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Plan {
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum UserProfile {
  ADMIN
  FINANCEIRO
  PROFISSIONAL
  AUXILIAR_TECNICO
  GESTOR_RELACIONAMENTO
  RECEPCIONISTA
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum TransactionType {
  INFLOW
  OUTFLOW
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique
  plan      Plan     @default(STANDARD)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                User[]
  patients             Patient[]
  appointments         Appointment[]
  transactions         Transaction[]
  auditLogs            AuditLog[]
  leads                Lead[]
  resources            Resource[]
  appointmentResources AppointmentResource[]
  ledgerAccounts       LedgerAccount[]
  ledgerEntries        LedgerEntry[]

  @@map("tenants")
}

model User {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String        @db.Uuid @map("tenant_id")
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String
  passwordHash String        @map("password_hash")
  profiles     UserProfile[]
  mfaEnabled   Boolean       @default(false) @map("mfa_enabled")
  mfaSecret    String?       @map("mfa_secret")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  appointments         Appointment[] @relation("ProfessionalAppointments")
  transactionsCreated  Transaction[] @relation("CreatedTransactions")
  auditLogs            AuditLog[]
  leads                Lead[]

  @@unique([tenantId, email])
  @@map("users")
}

model Patient {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid @map("tenant_id")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  cpf             String
  email           String?
  phone           String
  birthDate       DateTime? @map("birth_date")
  notes           String?
  clinicalHistory String?   @map("clinical_history")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  appointments Appointment[]
  transactions Transaction[]

  @@unique([tenantId, cpf])
  @@map("patients")
}

model Appointment {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String            @db.Uuid @map("tenant_id")
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId      String            @db.Uuid @map("patient_id")
  patient        Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professionalId String            @db.Uuid @map("professional_id")
  professional   User              @relation("ProfessionalAppointments", fields: [professionalId], references: [id], onDelete: Cascade)
  startTime      DateTime          @map("start_time")
  endTime        DateTime          @map("end_time")
  status         AppointmentStatus @default(PENDING)
  bufferMinutes  Int               @default(0) @map("buffer_minutes")
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  resources AppointmentResource[]

  @@map("appointments")
}

enum ResourceType {
  ROOM
  EQUIPMENT
  PROFISSIONAL
}

model Resource {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String       @db.Uuid @map("tenant_id")
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  type      ResourceType
  quantity  Int          @default(1)
  
  appointments AppointmentResource[]
  @@map("resources")
}

model AppointmentResource {
  appointmentId String      @db.Uuid @map("appointment_id")
  resourceId    String      @db.Uuid @map("resource_id")
  tenantId      String      @db.Uuid @map("tenant_id")
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  resource      Resource    @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@id([appointmentId, resourceId])
  @@map("appointment_resources")
}

model Transaction {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String             @db.Uuid @map("tenant_id")
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId   String?            @db.Uuid @map("patient_id")
  patient     Patient?           @relation(fields: [patientId], references: [id], onDelete: SetNull)
  description String
  status      TransactionStatus  @default(PENDING)
  createdById String             @db.Uuid @map("created_by_id")
  createdBy   User               @relation("CreatedTransactions", fields: [createdById], references: [id])
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  entries     LedgerEntry[]

  @@map("transactions")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model LedgerAccount {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String      @db.Uuid @map("tenant_id")
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  type      AccountType
  
  entries   LedgerEntry[]
  @@map("ledger_accounts")
}

model LedgerEntry {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String        @db.Uuid @map("tenant_id")
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactionId String        @db.Uuid @map("transaction_id")
  transaction   Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  accountId     String        @db.Uuid @map("account_id")
  account       LedgerAccount @relation(fields: [accountId], references: [id])
  debit         Decimal       @default(0) @db.Decimal(12, 2)
  credit        Decimal       @default(0) @db.Decimal(12, 2)
  
  @@map("ledger_entries")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String?  @db.Uuid @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  beforeState Json?   @map("before_state")
  afterState  Json?   @map("after_state")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

enum LeadStatus {
  NEW
  NEGOTIATION
  SCHEDULED
  WON
  LOST
}

model Lead {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String     @db.Uuid @map("tenant_id")
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  procedure      String?
  estimatedValue Decimal?   @db.Decimal(12, 2) @map("estimated_value")
  status         LeadStatus @default(NEW)
  source         String?
  probability    Int        @default(0)
  warningText    String?    @map("warning_text")
  notes          String?
  professionalId String?    @db.Uuid @map("professional_id")
  professional   User?      @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@map("leads")
}
